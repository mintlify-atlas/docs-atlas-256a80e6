  "keyFeatures": [
    "Zero external dependencies — pure Node.js standard library",
    "43 MCP tools across 8 categories (arithmetic, trig, stats, percentages, unit conversion, constants, memory, batch)",
    "Three tiered tool sets (minimal/standard/full) to optimize context token usage",
    "Safe expression evaluation with strict regex whitelist (no eval())",
    "Worker thread isolation with configurable 3-second timeout for heavy computations",
    "Accurate floating-point math via integer-scaling (0.1 + 0.2 === 0.3)",
    "80+ unit conversions across 8 categories",
    "16 mathematical and physical constants",
    "Fuzzy tool name matching with Levenshtein distance correction",
    "LRU result caching with 5-minute TTL"
  ],
  "publicApiSurface": [
    "evaluate_expression(expression: string)",
    "add(a: number, b: number)",
    "subtract(a: number, b: number)",
    "multiply(a: number, b: number)",
    "divide(a: number, b: number)",
    "modulo(a: number, b: number)",
    "power(base: number, exponent: number)",
    "sqrt(value: number)",
    "factorial(n: number)",
    "sine(angle: number, unit?: string)",
    "cosine(angle: number, unit?: string)",
    "tangent(angle: number, unit?: string)",
    "asin(value: number, unit?: string)",
    "acos(value: number, unit?: string)",
    "atan(value: number, unit?: string)",
    "logarithm(value: number)",
    "natural_log(value: number)",
    "absolute(value: number)",
    "get_constant(name: string)",
    "sum(numbers: number[])",
