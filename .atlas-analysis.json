    "percentile(numbers: number[], percentile: number)",
    "percentage_of(percent: number, total: number)",
    "percentage_change(from: number, to: number)",
    "percentage_reverse(value: number, percent: number)",
    "convert_unit(value: number, category: string, from: string, to: string)",
    "convert_base(value: string, from_base: number, to_base: number)",
    "set_angle_mode(unit: string)",
    "get_angle_mode()",
    "memory_add(value: number)",
